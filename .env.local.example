# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored — never commit real credentials.

# Mailtrap API token (Mailtrap dashboard -> Settings -> API Tokens)
MAILTRAP_API_TOKEN=your-mailtrap-api-token

# The "from" address Mailtrap sends as — must be a verified sender/domain,
# or Mailtrap's demo sending address if you're on the free trial
# (Email Sending -> Sending Domains in the Mailtrap dashboard)
MAILTRAP_SENDER_EMAIL=hello@yourdomain.com

# Where contact-form messages should land (your real inbox)
CONTACT_RECEIVER_EMAIL=hariharan23486@gmail.com
